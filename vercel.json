{
    "buildCommand": "cd client && npm install && npm run build",
    "outputDirectory": "client/dist",
    "rewrites": [
        {
            "source": "/api/admin/(.*)",
            "destination": "/api/admin/index.js"
        },
        {
            "source": "/api/billing/(.*)",
            "destination": "/api/billing/index.js"
        },
        {
            "source": "/api/payroll/(.*)",
            "destination": "/api/payroll/index.js"
        },
        {
            "source": "/api/commissions/(.*)",
            "destination": "/api/commissions/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/admin/dunning/cron/run",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/admin/dunning/cron/sync-paid",
            "schedule": "0 6 * * *"
        }
    ]
}
